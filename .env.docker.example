# STRIPE_PRICE_ID=

# --- External Services ---
FRED_API_KEY=your_fred_api_key
# RESEND_API_KEY=
# SENTRY_DSN=
# GA_ID=

# --- Admin ---
ADMIN_EMAILS=your_email@example.com
MFA_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32

