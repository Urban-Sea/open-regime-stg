# Docker environment variables template
# Copy to .env.docker and fill in values:  cp .env.docker.example .env.docker

# --- Database ---
DB_PASSWORD=changeme_local_dev

# --- Auth (Step 3) ---
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
